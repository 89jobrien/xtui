#!/usr/bin/env nu

# Pre-push: label and amend the outgoing commit.
#
# +patch  — auto-bumps 0.0.z and appends (+patch x.y.z)
# +minor  — detects 0.y.0 bump, appends (+minor x.y.0), no version change
# +major  — detects x.0.0 bump, appends (+major x.0.0), no version change

let cargo_toml = "Cargo.toml"

let version = (
    open $cargo_toml
    | lines
    | where { |l| ($l | str starts-with "version = \"") }
    | first
    | str replace --regex '^version = "(.+)"$' '$1'
)

let parts = ($version | split row ".")
let major = ($parts | get 0 | into int)
let minor = ($parts | get 1 | into int)
let patch = ($parts | get 2 | into int)

let msg = (git log -1 --format=%B | str trim)

if $patch != 0 {
    # Regular commit — bump patch and label
    let new_version = $"($major).($minor).($patch + 1)"

    open --raw $cargo_toml
    | str replace $"version = \"($version)\"" $"version = \"($new_version)\""
    | save --force $cargo_toml

    cargo generate-lockfile

    git add Cargo.toml Cargo.lock
    git commit --amend -m $"($msg)\n\n\(+patch ($new_version)\)"
    exit 0
}

# patch == 0 — release commit, detect minor vs major from last tag
let last_tag = (
    do { git describe --tags --match "xtui-v*" --abbrev=0 } | complete | get stdout | str trim
)

let label = if ($last_tag | is-empty) {
    # No prior tag — treat as initial release, label by version shape
    if $minor == 0 { "+major" } else { "+minor" }
} else {
    let prev = ($last_tag | str replace "xtui-v" "" | split row ".")
    let prev_major = ($prev | get 0 | into int)
    let prev_minor = ($prev | get 1 | into int)
    if $major > $prev_major {
        "+major"
    } else if $minor > $prev_minor {
        "+minor"
    } else {
        # Same major.minor — already tagged this version, nothing to do
        exit 0
    }
}

git commit --amend -m $"($msg)\n\n\(($label) ($version)\)"
