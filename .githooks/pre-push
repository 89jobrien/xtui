#!/usr/bin/env nu

# Pre-push: version bump and release automation.
#
# (+minor) or (+major) in the commit message → run cargo-rail release
# Otherwise → implied +patch auto-bump
#
# CI will reject any push missing a version label.

# Refresh dev-state, then verify it is coherent before allowing push
cargo xtask dev-state
cargo xtask dev-state --verify
if ($env.LAST_EXIT_CODE != 0) {
    print "Push blocked: dev-state failed verification after refresh."
    exit 1
}

let cargo_toml = "Cargo.toml"

let version = (
    open --raw $cargo_toml
    | lines
    | where { |l| ($l | str starts-with "version = \"") }
    | first
    | str replace --regex '^version = "(.+)"$' '$1'
)

let parts = ($version | split row ".")
let major = ($parts | get 0 | into int)
let minor = ($parts | get 1 | into int)
let patch_str = ($parts | get 2)
# Detect pre-release suffix (e.g. "5-rc.1")
let has_prerelease = ($patch_str | str contains "-")
let patch = ($patch_str | split row "-" | first | into int)

let msg = (git log -1 --format=%B | str trim)

# --- Minor / major release ---
let bump = if ($msg | str contains "(+minor)") {
    "minor"
} else if ($msg | str contains "(+major)") {
    "major"
} else {
    ""
}

if ($bump | is-not-empty) {
    # Rail handles version bump, changelog, commit, and tag
    cargo rail release run xtui $"--bump=($bump)" --skip-publish --yes
    exit 0
}

# --- Patch bump ---
# If current version has a pre-release suffix, promote to clean release (strip suffix).
# Otherwise bump the patch number.
let new_version = if $has_prerelease {
    $"($major).($minor).($patch)"
} else {
    $"($major).($minor).($patch + 1)"
}

open --raw $cargo_toml
| str replace $"version = \"($version)\"" $"version = \"($new_version)\""
| save --force $cargo_toml

cargo generate-lockfile

git add Cargo.toml Cargo.lock
git commit --amend -m $"($msg)\n\n\(+patch ($new_version)\)"

cargo xtask dev-state
