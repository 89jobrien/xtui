#!/usr/bin/env nu

# Pre-push: verify xstate is coherent before allowing push.
# Version bumping happens in CI (promote job: FF-merge develop → main + rail patch bump).

cargo xtask xstate
cargo xtask xstate --verify
if ($env.LAST_EXIT_CODE != 0) {
    print "Push blocked: xstate failed verification. Run `cargo xtask xstate` to resync."
    exit 1
}
